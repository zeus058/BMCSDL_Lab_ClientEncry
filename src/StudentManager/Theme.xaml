<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:StudentManager.Helpers">
    <helpers:StringToVisibilityConverter x:Key="StringToVis" />
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <FontFamily x:Key="AppFont">./Fonts/#Montserrat</FontFamily>

    <Color x:Key="ColorBgBase">#FFF4F7FB</Color>
    <Color x:Key="ColorBgSurface1">#FFFFFFFF</Color>
    <Color x:Key="ColorBgSurface2">#FFF8FAFC</Color>
    <Color x:Key="ColorBgSidebar">#FFFFFFFF</Color>
    <Color x:Key="ColorAccent">#FF0F766E</Color>
    <Color x:Key="ColorAccentDark">#FF115E59</Color>
    <Color x:Key="ColorAccentSoft">#FFDDF7F3</Color>
    <Color x:Key="ColorTextPrimary">#FF0F172A</Color>
    <Color x:Key="ColorTextSecondary">#FF334155</Color>
    <Color x:Key="ColorTextMuted">#FF64748B</Color>
    <Color x:Key="ColorDanger">#FFDC2626</Color>
    <Color x:Key="ColorWarning">#FFD97706</Color>
    <Color x:Key="ColorDivider">#FFE2E8F0</Color>
    <Color x:Key="ColorInputBg">#FFFFFFFF</Color>
    <Color x:Key="ColorInputBorder">#FFCBD5E1</Color>
    <Color x:Key="ColorSurfaceHover">#FFF7FAFC</Color>
    <Color x:Key="ColorDangerDark">#FFB91C1C</Color>
    <Color x:Key="ColorDangerSoft">#FFFDE8E8</Color>
    <Color x:Key="ColorDangerBorder">#FFF9B6B6</Color>

    <SolidColorBrush x:Key="BgBase" Color="{StaticResource ColorBgBase}" />
    <SolidColorBrush x:Key="BgSurface1" Color="{StaticResource ColorBgSurface1}" />
    <SolidColorBrush x:Key="BgSurface2" Color="{StaticResource ColorBgSurface2}" />
    <SolidColorBrush x:Key="BgSidebar" Color="{StaticResource ColorBgSidebar}" />
    <SolidColorBrush x:Key="HoverSurface" Color="{StaticResource ColorSurfaceHover}" />
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushDangerDark" Color="{StaticResource ColorDangerDark}" />
    <SolidColorBrush x:Key="BrushDangerSoft" Color="{StaticResource ColorDangerSoft}" />
    <SolidColorBrush x:Key="BrushDangerBorder" Color="{StaticResource ColorDangerBorder}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushDivider" Color="{StaticResource ColorDivider}" />
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource ColorInputBg}" />
    <SolidColorBrush x:Key="InputBorder" Color="{StaticResource ColorInputBorder}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="AccentBrushDark" Color="{StaticResource ColorAccentDark}" />
    <SolidColorBrush x:Key="AccentBrushSoft" Color="{StaticResource ColorAccentSoft}" />

    <!-- Viền focus khi Tab — không ảnh hưởng hit test -->
    <Style x:Key="AppButtonFocusVisual" TargetType="Control">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="-2"
                               SnapsToDevicePixels="True"
                               Stroke="{StaticResource AccentBrush}"
                               StrokeThickness="2"
                               RadiusX="12"
                               RadiusY="12"
                               IsHitTestVisible="False"
                               Opacity="0.85" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DropShadowEffect x:Key="CardShadow"
                      Color="#140F172A"
                      BlurRadius="24"
                      ShadowDepth="4"
                      Direction="270"
                      Opacity="0.22" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrushDark}" />
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSurface1}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="GhostBtn" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurface1}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="MinWidth" Value="116" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource AppButtonFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InputBorder}" />
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource HoverSurface}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <!-- Xám rõ ràng — không dùng opacity thấp để tránh button gần vô hình -->
                <Setter Property="Background" Value="#EAECEF" />
                <Setter Property="BorderBrush" Value="#C8CDD5" />
                <Setter Property="Foreground" Value="#9AA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryBtnFixed" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
        <Style.Resources>
            <!-- Buộc TextBlock bên trong button (như icon + text) phải dùng Foreground của button (Trắng) -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
            </Style>
        </Style.Resources>
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="20,11" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrushDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrushDark}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrushDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrushDark}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#EAECEF" />
                <Setter Property="BorderBrush" Value="#C8CDD5" />
                <Setter Property="Foreground" Value="#9AA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
            </Style>
        </Style.Resources>
        <Setter Property="Background" Value="#FFFDE2E2" />
        <Setter Property="BorderBrush" Value="#FFF3B2B2" />
        <Setter Property="Foreground" Value="{StaticResource BrushDangerDark}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushDanger}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushDanger}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushDangerDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushDangerDark}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#EAECEF" />
                <Setter Property="BorderBrush" Value="#C8CDD5" />
                <Setter Property="Foreground" Value="#9AA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Ghost toolbar button — border rõ hơn, hover đậm -->
    <Style x:Key="ToolbarBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
        <Setter Property="Background" Value="{StaticResource BgSurface1}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="24,13" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Primary toolbar button — solid accent -->
    <Style x:Key="ToolbarPrimaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtnFixed}">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
            </Style>
        </Style.Resources>
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="24,13" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Danger toolbar button — solid red để cùng visual weight với primary -->
    <Style x:Key="ToolbarDangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
            </Style>
        </Style.Resources>
        <Setter Property="Background" Value="{StaticResource BrushDangerSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushDangerBorder}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Foreground" Value="{StaticResource BrushDangerDark}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="24,13" />
        <Setter Property="FontSize" Value="14" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushDanger}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushDanger}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushDangerDark}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushDangerDark}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#EAECEF" />
                <Setter Property="BorderBrush" Value="#C8CDD5" />
                <Setter Property="Foreground" Value="#9AA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Background="{StaticResource BgSurface2}"
                            BorderBrush="{StaticResource BrushDivider}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrushSoft}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource BgSurface1}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="RowBackground" Value="{StaticResource BgSurface1}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BgSurface2}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="SelectionUnit" Value="FullRow" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource BgSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="MinHeight" Value="58" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrushSoft}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource AccentBrushDark}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BrushDivider}" />
    </Style>

    <SolidColorBrush x:Key="ObsidianBlack" Color="{StaticResource ColorBgBase}" />
    <SolidColorBrush x:Key="PetronasGreen" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="Silver" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="IneosRed" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="PanelBackground" Color="{StaticResource ColorBgSurface1}" />
    <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource CardBorder}" />
    <Style x:Key="HeaderTextBlock" TargetType="TextBlock" BasedOn="{StaticResource PageTitle}" />
    <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtnFixed}">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
            </Style>
        </Style.Resources>
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinHeight" Value="38" />
    </Style>
    <Style x:Key="StandardDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}" />
    <Style x:Key="NavItemBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,13" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style x:Key="SubtitleTextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="Margin" Value="0,0,0,20" />
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}" />
</ResourceDictionary>
