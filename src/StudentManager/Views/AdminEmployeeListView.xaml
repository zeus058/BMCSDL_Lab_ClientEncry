<UserControl x:Class="StudentManager.Views.AdminEmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:AdminEmployeeListViewModel}">
    <UserControl.Resources>
        <!-- Standard Cell -->
        <Style x:Key="SvCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Monospace and bold ID -->
        <Style x:Key="SvIdCellText" TargetType="TextBlock" BasedOn="{StaticResource SvCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <!-- Centered cell text -->
        <Style x:Key="SvCenterCellText" TargetType="TextBlock" BasedOn="{StaticResource SvCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <!-- Centered column header -->
        <Style x:Key="CenteredColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,4,0,18">
            <TextBlock Text="Danh sách nhân viên" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Xem danh sách nhân viên hiện tại trong hệ thống (thông tin lương đã được bảo mật hoàn toàn)."
                       Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid ItemsSource="{Binding Employees}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã nhân viên"
                                        Binding="{Binding MANV}"
                                        Width="140"
                                        HeaderStyle="{StaticResource CenteredColHeader}"
                                        ElementStyle="{StaticResource SvIdCellText}" />
                    <DataGridTextColumn Header="Họ tên"
                                        Binding="{Binding HOTEN}"
                                        Width="*"
                                        ElementStyle="{StaticResource SvCellText}" />
                    <DataGridTextColumn Header="Email"
                                        Binding="{Binding EMAIL}"
                                        Width="220"
                                        ElementStyle="{StaticResource SvCellText}" />
                    <DataGridTextColumn Header="Tên đăng nhập"
                                        Binding="{Binding TENDN}"
                                        Width="160"
                                        HeaderStyle="{StaticResource CenteredColHeader}"
                                        ElementStyle="{StaticResource SvCenterCellText}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}" 
                   Margin="0,12,0,0" 
                   Foreground="{StaticResource AccentBrushDark}" 
                   FontStyle="Italic"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />
    </Grid>
</UserControl>
