<UserControl x:Class="StudentManager.Views.StaffProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StudentManager.Helpers"
             xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:StaffProfileViewModel}">
    <UserControl.Resources>
        <!-- Standard Cell -->
        <Style x:Key="SvCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Monospace and bold ID -->
        <Style x:Key="SvIdCellText" TargetType="TextBlock" BasedOn="{StaticResource SvCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <!-- Centered cell text -->
        <Style x:Key="SvCenterCellText" TargetType="TextBlock" BasedOn="{StaticResource SvCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <!-- Centered column header -->
        <Style x:Key="CenteredColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <!-- BooleanToVisibilityConverter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisLocal" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,4,0,18">
            <TextBlock Text="Nhân viên" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Xem hồ sơ cá nhân của bạn và quản lý danh sách nhân viên trong hệ thống."
                       Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <TabControl Grid.Row="1" SelectionChanged="TabControl_SelectionChanged">
            <!-- ========== TAB 1: HỒ SƠ CÁ NHÂN ========== -->
            <TabItem Header="Hồ sơ cá nhân">
                <Grid Margin="0,12,0,0">
                    <Border Style="{StaticResource CardBorder}" 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="600"
                            Padding="24">
                        <StackPanel>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="80" Height="80" 
                                        CornerRadius="40" 
                                        Background="{StaticResource AccentBrush}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" 
                                               Text="&#xE77B;" 
                                               FontSize="36" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Hoten}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Text="{Binding Manv}" FontSize="14" Foreground="{StaticResource AccentBrushDark}" FontFamily="Consolas" />
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,0,0,24" Background="{StaticResource BrushDivider}" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Email:" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Email}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên đăng nhập:" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Tendn}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Nhập mật khẩu để xem lương:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <PasswordBox x:Name="SalPass" Width="220" Height="38" Margin="0,0,12,0" 
                                                 PasswordChanged="PasswordBox_PasswordChanged" VerticalContentAlignment="Center" />
                                    <Button Content="Xem lương" 
                                            Command="{Binding LoadDecryptedSalaryCommand}"
                                            Style="{StaticResource ActionBtn}"
                                            Padding="25,0" Height="38"
                                            Foreground="White" />
                                </StackPanel>

                                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                                        Background="{StaticResource BgSurface2}" 
                                        CornerRadius="8" 
                                        Padding="16" 
                                        Visibility="{Binding DecryptedLuongcb, Converter={StaticResource StringToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Lương cơ bản của bạn là: " Foreground="{StaticResource TextPrimary}" />
                                        <TextBlock Text="{Binding DecryptedLuongcb, StringFormat={}{0:N0} VNĐ}" 
                                                   FontWeight="Bold" 
                                                   Foreground="{StaticResource AccentBrushDark}" 
                                                   FontSize="18" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="{Binding StatusMessage}" 
                                       Margin="0,20,0,0" 
                                       Foreground="{StaticResource AccentBrushDark}" 
                                       FontStyle="Italic"
                                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ========== TAB 2: DANH SÁCH NHÂN VIÊN (chỉ xem) ========== -->
            <TabItem Header="Danh sách nhân viên">
                <Grid Margin="0,12,0,0">
                    <Border Style="{StaticResource CardBorder}" Padding="0">
                        <DataGrid ItemsSource="{Binding Employees}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã nhân viên"
                                                    Binding="{Binding MANV}"
                                                    Width="140"
                                                    HeaderStyle="{StaticResource CenteredColHeader}"
                                                    ElementStyle="{StaticResource SvIdCellText}" />
                                <DataGridTextColumn Header="Họ tên"
                                                    Binding="{Binding HOTEN}"
                                                    Width="*"
                                                    ElementStyle="{StaticResource SvCellText}" />
                                <DataGridTextColumn Header="Email"
                                                    Binding="{Binding EMAIL}"
                                                    Width="200"
                                                    ElementStyle="{StaticResource SvCellText}" />
                                <DataGridTextColumn Header="Tên đăng nhập"
                                                    Binding="{Binding TENDN}"
                                                    Width="150"
                                                    HeaderStyle="{StaticResource CenteredColHeader}"
                                                    ElementStyle="{StaticResource SvCenterCellText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ========== TAB 3: ADMIN MANAGER ========== -->
            <TabItem Header="Admin Manager">
                <Grid Margin="0,12,0,0">
                    <!-- LOCKED STATE: Nhập mật khẩu admin -->
                    <Border Style="{StaticResource CardBorder}" 
                            Padding="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="480"
                            Visibility="{Binding IsAdminUnlocked, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel>
                            <Border Width="64" Height="64" 
                                    CornerRadius="32" 
                                    Background="{StaticResource AccentBrushSoft}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,18">
                                <TextBlock Text="🔒" FontSize="28" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" />
                            </Border>

                            <TextBlock Text="Xác thực Admin"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Nhập mật khẩu quản trị viên để truy cập chức năng quản lý lương."
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,8,0,20" />

                            <TextBlock Text="Mật khẩu Admin"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="AdminPass"
                                         PasswordChanged="AdminPasswordBox_PasswordChanged"
                                         Padding="10,8"
                                         Margin="0,0,0,16" />

                            <Button Content="Xác thực"
                                    Command="{Binding UnlockAdminCommand}"
                                    Style="{StaticResource PrimaryBtnFixed}"
                                    Height="40" />

                            <TextBlock Text="{Binding AdminStatusMessage}"
                                       Foreground="{StaticResource BrushDanger}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding AdminStatusMessage, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- UNLOCKED STATE: Giao diện quản lý lương -->
                    <Grid Visibility="{Binding IsAdminUnlocked, Converter={StaticResource BoolToVisLocal}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="36" Height="36" 
                                    CornerRadius="10" 
                                    Background="{StaticResource AccentBrushSoft}"
                                    Margin="0,0,12,0">
                                <TextBlock Text="🔓" FontSize="18" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Admin Manager"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Cập nhật lương cơ bản cho nhân viên (mã hóa RSA bằng Public Key của nhân viên)"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Danh sách nhân viên (chọn để cập nhật lương) -->
                        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid ItemsSource="{Binding AdminEmployees}"
                                      SelectedItem="{Binding SelectedAdminEmployee}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã NV"
                                                        Binding="{Binding MANV}"
                                                        Width="120"
                                                        HeaderStyle="{StaticResource CenteredColHeader}"
                                                        ElementStyle="{StaticResource SvIdCellText}" />
                                    <DataGridTextColumn Header="Họ tên"
                                                        Binding="{Binding HOTEN}"
                                                        Width="*"
                                                        ElementStyle="{StaticResource SvCellText}" />
                                    <DataGridTextColumn Header="Email"
                                                        Binding="{Binding EMAIL}"
                                                        Width="180"
                                                        ElementStyle="{StaticResource SvCellText}" />
                                    <DataGridTextColumn Header="Tên đăng nhập"
                                                        Binding="{Binding TENDN}"
                                                        Width="130"
                                                        HeaderStyle="{StaticResource CenteredColHeader}"
                                                        ElementStyle="{StaticResource SvCenterCellText}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Form cập nhật lương -->
                        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Cập nhật lương" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="140" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="Lương cơ bản mới:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontWeight="SemiBold" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding NewLuong, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" />
                                    <Button Grid.Column="3"
                                            Command="{Binding UpdateSalaryCommand}"
                                            Style="{StaticResource ToolbarPrimaryBtn}"
                                            MinWidth="160">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" Margin="0,0,8,0" />
                                            <TextBlock Text="Cập nhật lương" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <TextBlock Text="{Binding AdminStatusMessage}"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding AdminStatusMessage, Converter={StaticResource StringToVis}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
