<Window x:Class="StudentManager.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:StudentManager.Helpers"
        xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
        Title="Đổi mật khẩu"
        Width="500"
        Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}"
        x:Name="ChangePwWin">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Border Width="40"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource AccentBrushSoft}"
                        Margin="0,0,12,0">
                    <TextBlock Text="🔑" 
                               FontSize="20" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BẢO MẬT HỆ THỐNG"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrushDark}"/>
                    <TextBlock Text="Đổi Mật Khẩu Cá Nhân"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                </StackPanel>
            </StackPanel>
            
            <TextBlock Text="Lưu ý: Hệ thống sẽ tự động giải mã mức lương và toàn bộ điểm số của sinh viên bằng mật khẩu cũ, sau đó mã hóa lại bằng mật khẩu mới để bảo vệ an toàn thông tin."
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            
            <Border BorderBrush="{StaticResource BrushDivider}"
                    BorderThickness="0,0,0,1"
                    Margin="0,12,0,0" />
        </StackPanel>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Mã Nhân Viên -->
                <TextBlock Text="Mã Nhân Viên" 
                           Foreground="{StaticResource TextSecondary}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding Manv, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" 
                         Padding="10,8" />

                <!-- Mật khẩu cũ -->
                <TextBlock Text="Mật khẩu hiện tại" 
                           Foreground="{StaticResource TextSecondary}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,6" />
                <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                             helpers:PasswordBoxAssistant.BoundPassword="{Binding OldPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" 
                             Padding="10,8" />

                <!-- Mật khẩu mới -->
                <TextBlock Text="Mật khẩu mới (tối thiểu 6 ký tự)" 
                           Foreground="{StaticResource TextSecondary}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,6" />
                <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                             helpers:PasswordBoxAssistant.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" 
                             Padding="10,8" />

                <!-- Xác nhận mật khẩu mới -->
                <TextBlock Text="Xác nhận mật khẩu mới" 
                           Foreground="{StaticResource TextSecondary}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,6" />
                <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                             helpers:PasswordBoxAssistant.BoundPassword="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" 
                             Padding="10,8" />

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource BrushDanger}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Action Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="Hủy bỏ"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding ElementName=ChangePwWin}"
                    Style="{StaticResource GhostBtn}"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Height="40"
                    IsEnabled="{Binding CanExecuteChange}" />

            <Button Content="Xác nhận"
                    Command="{Binding ChangePasswordCommand}"
                    Style="{StaticResource PrimaryBtnFixed}"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Height="40"
                    IsEnabled="{Binding CanExecuteChange}"
                    IsDefault="True" />
        </Grid>
    </Grid>
</Window>
