<Window x:Class="StudentManager.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:StudentManager.Helpers"
        xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
        Title="Kimi - Đăng nhập"
        Width="1240"
        Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/app_icon.ico"
        Background="{StaticResource BgBase}">
    <Window.DataContext>
        <viewmodels:LoginViewModel />
    </Window.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <Grid Margin="32"
              HorizontalAlignment="Center"
              MaxWidth="1180">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,28,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="54"
                                Height="54"
                                CornerRadius="16"
                                Background="{StaticResource AccentBrush}"
                                Margin="0,0,14,0">
                            <Image Source="pack://application:,,,/Assets/app_icon.ico"
                                   Width="36"
                                   Height="36"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Kimi"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="Hệ thống quản lý sinh viên"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="14" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Ứng dụng quản lý sinh viên đơn giản, hiện đại và chuyên nghiệp"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="18"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,22,0,0">
                        <Border Background="{StaticResource AccentBrushSoft}"
                                BorderBrush="{StaticResource BrushDivider}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="Xem thông tin lớp học"
                                       Foreground="{StaticResource AccentBrushDark}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{StaticResource AccentBrushSoft}"
                                BorderBrush="{StaticResource BrushDivider}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="Điểm thi được mã hóa"
                                       Foreground="{StaticResource AccentBrushDark}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{StaticResource AccentBrushSoft}"
                                BorderBrush="{StaticResource BrushDivider}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="14,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="Giao diện dễ sử dụng"
                                       Foreground="{StaticResource AccentBrushDark}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>

                    <Border Style="{StaticResource CardBorder}" Margin="0,28,0,0" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="188" />
                            </Grid.ColumnDefinitions>

                            <Image Source="pack://application:,,,/Assets/login_student_management.png"
                                   Height="290"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True" />

                            <StackPanel Grid.Column="1"
                                        Margin="18,0,0,0"
                                        VerticalAlignment="Center">
                                <Border Background="{StaticResource BgSurface2}"
                                        BorderBrush="{StaticResource BrushDivider}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Lớp học"
                                                   Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="Theo dõi lớp do nhân viên phụ trách."
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource BgSurface2}"
                                        BorderBrush="{StaticResource BrushDivider}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Sinh viên"
                                                   Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="Cập nhật hồ sơ và phân lớp chính xác."
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource BgSurface2}"
                                        BorderBrush="{StaticResource BrushDivider}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Bảng điểm"
                                                   Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="Nhập điểm an toàn với cơ chế mã hóa."
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorder}"
                    Padding="32"
                    VerticalAlignment="Center"
                    MaxWidth="420">
                <StackPanel>
                    <TextBlock Text="Truy cập hệ thống"
                               Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Đăng nhập"
                               Style="{StaticResource PageTitle}"
                               FontSize="28" />
                    <TextBlock Text="Sử dụng Mã Nhân Viên để truy cập hệ thống"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,24"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Mã Nhân Viên" Margin="0,0,0,6" />
                    <TextBox Text="{Binding LoginId, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16" />

                    <TextBlock Text="Mật khẩu" Margin="0,0,0,6" />
                    <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                                 helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,22" />

                    <Button Content="Quên mật khẩu / Đổi mật khẩu"
                            Command="{Binding OpenChangePasswordCommand}"
                            Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource AccentBrushDark}"
                            Cursor="Hand"
                            Margin="0,-16,0,16" />

                    <Button Content="Đăng nhập"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryBtnFixed}" />

                    <Border Background="{StaticResource BgSurface2}"
                            BorderBrush="{StaticResource BrushDivider}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,22,0,0">
                        <StackPanel>
                            <TextBlock Text="Tài khoản demo"
                                       Style="{StaticResource SectionTitle}" />
                            <UniformGrid Columns="2" Margin="0,12,0,0">
                                <Border Background="White"
                                        CornerRadius="12"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="NV01"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontWeight="Bold"
                                                   FontFamily="Consolas" />
                                        <TextBlock Text="abcd12"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" />
                                    </StackPanel>
                                </Border>

                                <Border Background="White"
                                        CornerRadius="12"
                                        Padding="12"
                                        Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="NV02"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontWeight="Bold"
                                                   FontFamily="Consolas" />
                                        <TextBlock Text="pass123"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource BrushDanger}"
                               FontWeight="SemiBold"
                               Margin="0,16,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
