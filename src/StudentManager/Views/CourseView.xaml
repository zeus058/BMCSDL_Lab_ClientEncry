<UserControl x:Class="StudentManager.Views.CourseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:CourseViewModel}">
    <UserControl.Resources>
        <Style x:Key="HpCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Mã HP: căn giữa, monospace -->
        <Style x:Key="HpIdCellText" TargetType="TextBlock" BasedOn="{StaticResource HpCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <!-- Số tín chỉ: căn giữa -->
        <Style x:Key="HpCenterCellText" TargetType="TextBlock" BasedOn="{StaticResource HpCellText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="HpCenteredHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="280" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,4,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0,0,0,10">
                <TextBlock Text="Học phần" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Quản lý danh mục học phần dùng cho việc nhập bảng điểm."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextMuted}" />
            </StackPanel>

            <Grid Grid.Column="2"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource ToolbarBtn}" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE72C;"
                                       Margin="0,0,8,0"
 />
                            <TextBlock Text="Làm mới"
 />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewCommand}" Style="{StaticResource ToolbarBtn}" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE710;"
                                       Margin="0,0,8,0"
 />
                            <TextBlock Text="Tạo học phần"
 />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource ToolbarPrimaryBtn}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE74E;"
                                       Margin="0,0,8,0"
 />
                            <TextBlock Text="Lưu học phần"
 />
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Button Grid.Column="2"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource ToolbarDangerBtn}"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE74D;"
                                   Margin="0,0,8,0"
 />
                        <TextBlock Text="Xóa học phần"
 />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HP"
                                        Binding="{Binding MAHP}"
                                        Width="140"
                                        HeaderStyle="{StaticResource HpCenteredHeader}"
                                        ElementStyle="{StaticResource HpIdCellText}" />
                    <DataGridTextColumn Header="Tên học phần"
                                        Binding="{Binding TENHP}"
                                        Width="*"
                                        ElementStyle="{StaticResource HpCellText}" />
                    <DataGridTextColumn Header="Số tín chỉ"
                                        Binding="{Binding SOTC}"
                                        Width="130"
                                        HeaderStyle="{StaticResource HpCenteredHeader}"
                                        ElementStyle="{StaticResource HpCenterCellText}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiết học phần"
                           Style="{StaticResource SectionTitle}"
                           Margin="0,0,0,16" />

                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Mã học phần" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditMahp, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsMahpReadOnly}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Tên học phần" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditTenhp, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Số tín chỉ" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditSotc, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource AccentBrushDark}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
