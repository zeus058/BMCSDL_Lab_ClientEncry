<UserControl x:Class="StudentManager.Views.GradeEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:GradeEntryViewModel}">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,4,0,18">
            <TextBlock Text="Nhập điểm sinh viên" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Chọn sinh viên, học phần và nhập điểm số. Điểm sẽ được mã hóa bảo mật."
                       Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <!-- Input Section -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sinh viên:" Style="{StaticResource FieldLabel}" />
                <ComboBox Grid.Row="2" Grid.Column="0"
                          ItemsSource="{Binding Students}"
                          SelectedItem="{Binding SelectedStudent}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="MASV" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Học phần:" Style="{StaticResource FieldLabel}" />
                <ComboBox Grid.Row="2" Grid.Column="2"
                          ItemsSource="{Binding HocPhans}"
                          SelectedItem="{Binding SelectedHocPhan}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="MAHP" />

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Điểm số:" Style="{StaticResource FieldLabel}" />
                <TextBox Grid.Row="2" Grid.Column="4"
                         Text="{Binding EditDiem, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center" />

                <Button Grid.Row="2" Grid.Column="6"
                         Content="Nhập điểm"
                         Command="{Binding SaveGradeCommand}"
                         Style="{StaticResource ActionBtn}"
                         Padding="30,8"
                         VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <!-- History Log Section -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource BgSurface2}" Padding="16" CornerRadius="16,16,0,0">
                    <Grid>
                        <TextBlock Text="Lịch sử cập nhật điểm" Style="{StaticResource SectionTitle}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrushDark}" FontStyle="Italic" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <DataGrid ItemsSource="{Binding HistoryLog}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeight="48"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BrushDivider}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="15,12" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="0" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding Timestamp}" Width="110">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="0,12" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Mã SV" Binding="{Binding Masv}" Width="100">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="0,12" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontFamily" Value="Consolas" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Họ tên sinh viên" Binding="{Binding HotenSv}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="15,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Học phần" Binding="{Binding Tenhp}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="15,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Điểm vừa nhập" Binding="{Binding Diem}" Width="150">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="0,12" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="FontSize" Value="16" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
