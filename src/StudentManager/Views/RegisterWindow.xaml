<Window x:Class="StudentManager.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:StudentManager.Helpers"
        xmlns:viewmodels="clr-namespace:StudentManager.ViewModels"
        Title="Đăng ký tài khoản nhân viên"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}"
        x:Name="RegisterWin">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Border Width="40"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource AccentBrushSoft}"
                        Margin="0,0,12,0">
                    <TextBlock Text="📝" 
                               FontSize="20" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TẠO TÀI KHOẢN MỚI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrushDark}"/>
                    <TextBlock Text="Đăng Ký Nhân Viên"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                </StackPanel>
            </StackPanel>
            
            <TextBlock Text="Hệ thống sẽ tự động sinh cặp khóa RSA-2048 và mã hóa lương cơ bản bằng khóa công khai của bạn trước khi lưu vào cơ sở dữ liệu."
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            
            <Border BorderBrush="{StaticResource BrushDivider}"
                    BorderThickness="0,0,0,1"
                    Margin="0,12,0,0" />
        </StackPanel>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Row 1: Mã NV + Họ tên -->
                <UniformGrid Columns="2" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Mã Nhân Viên (*)" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding Manv, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Họ tên (*)" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding Hoten, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" />
                    </StackPanel>
                </UniformGrid>

                <!-- Row 2: Email + Tên đăng nhập -->
                <UniformGrid Columns="2" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Email" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Tên đăng nhập (*)" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding Tendn, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" />
                    </StackPanel>
                </UniformGrid>

                <!-- Row 3: Mật khẩu + Xác nhận -->
                <UniformGrid Columns="2" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Mật khẩu (*)" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                                     helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Xác nhận mật khẩu (*)" 
                                   Foreground="{StaticResource TextSecondary}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" />
                        <PasswordBox helpers:PasswordBoxAssistant.BindPassword="True"
                                     helpers:PasswordBoxAssistant.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8" />
                    </StackPanel>
                </UniformGrid>

                <!-- Row 4: Lương cơ bản -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Lương cơ bản (*)" 
                               Foreground="{StaticResource TextSecondary}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding Luong, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             Width="240"
                             HorizontalAlignment="Left" />
                </StackPanel>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource BrushDanger}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Action Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="Hủy bỏ"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding ElementName=RegisterWin}"
                    Style="{StaticResource GhostBtn}"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Height="40"
                    IsEnabled="{Binding CanExecute}" />

            <Button Content="Đăng ký"
                    Command="{Binding RegisterCommand}"
                    Style="{StaticResource PrimaryBtnFixed}"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Height="40"
                    IsEnabled="{Binding CanExecute}"
                    IsDefault="True" />
        </Grid>
    </Grid>
</Window>
